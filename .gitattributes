# Auto-detect text files and normalize line endings to LF on commit.
* text=auto eol=lf

# Keep shell scripts and Node bin entry points as LF on all platforms.
*.sh    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Mark generated / vendored files so GitHub Linguist excludes them from
# the language statistics. Without this, package-lock.json and any
# committed build output skew the language bar away from TypeScript.
package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true
pnpm-lock.yaml      linguist-generated=true
dist/**             linguist-generated=true
build/**            linguist-generated=true

# Force TypeScript classification for .ts source. Without this, Linguist's
# `.ts` heuristic can fall through to the `#!/usr/bin/env node` shebang
# and mis-classify the file as JavaScript, which is what was driving the
# language bar to JS 100%.
*.ts                linguist-language=TypeScript
*.tsx               linguist-language=TypeScript
*.cts               linguist-language=TypeScript
*.mts               linguist-language=TypeScript
*.ts                linguist-detectable=true

# Treat lockfiles as binary for diffs to keep PRs readable.
package-lock.json   -diff
yarn.lock           -diff
pnpm-lock.yaml      -diff
